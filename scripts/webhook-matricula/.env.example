# ===================================================
# .env.example — WEBHOOK MATRÍCULA — EDUCA COM TALENTO
# Copie para .env e preencha com valores reais.
# NUNCA commite o arquivo .env no repositório!
# ===================================================

# --- MOODLE ---
MOODLE_URL=https://cursos.educacomtalento.com
MOODLE_TOKEN=SEU_TOKEN_AQUI
MOODLE_ROLE_ID=5

# --- HOTMART ---
# Hottok configurado em: Ferramentas > Webhooks no painel Hotmart
HOTMART_HOTTOK=SEU_HOTTOK_AQUI

# Mapeamento: HOTMART_MAP_<ID_PRODUTO>=<ID_CURSO_MOODLE>
# Exemplo (substitua pelos IDs reais):
HOTMART_MAP_123456=2
HOTMART_MAP_789012=3

# --- KIWIFY ---
# Secret configurado em: Configurações > Webhooks no painel Kiwify
KIWIFY_SECRET=SEU_SECRET_AQUI

# Mapeamento: KIWIFY_MAP_<ID_PRODUTO>=<ID_CURSO_MOODLE>
KIWIFY_MAP_prod_abc123=2
KIWIFY_MAP_prod_def456=3

# --- E-MAIL (Gmail com App Password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@educacomtalento.com
SMTP_PASS=SUA_APP_PASSWORD_GMAIL
EMAIL_FROM=noreply@educacomtalento.com

# --- SERVIÇO ---
WEBHOOK_PORT=5000
LOG_DIR=/app/logs
